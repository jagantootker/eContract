# ─────────────────────────────────────────────────────────────────────────────
# Docker environment variables template
# Copy to .env.docker and fill in real values before running docker compose.
#   cp .env.docker.example .env.docker
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootsecretchangeme
DB_DATABASE=ekontract_api
DB_USERNAME=ekontrak
DB_PASSWORD=secretchangeme

# ── Application Keys ──────────────────────────────────────────────────────────
# Generate a key with:
#   docker run --rm php:8.3-cli php -r \
#     "echo 'base64:' . base64_encode(random_bytes(32)) . PHP_EOL;"
BACKEND_APP_KEY=
FRONTEND_APP_KEY=

# ── Production: Docker Hub & Server ──────────────────────────────────────────
# Required only for docker-compose.prod.yml
DOCKERHUB_USERNAME=YOUR_DOCKERHUB_USERNAME
IMAGE_TAG=latest
SERVER_IP=YOUR_LIGHTSAIL_PUBLIC_IP

# ── Mail (optional – defaults to 'log' driver so emails go to storage/logs) ──
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
